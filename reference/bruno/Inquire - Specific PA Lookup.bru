script:pre-request {
  function uuid() {
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
      var r = Math.random() * 16 | 0;
      return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);
    });
  }

  bru.setVar("claimUuid", uuid());
  bru.setVar("coverageUuid", uuid());
  bru.setVar("encounterUuid", uuid());
  bru.setVar("patientUuid", uuid());
  bru.setVar("serviceRequestUuid", uuid());
  bru.setVar("requestorOrgUuid", uuid());
  bru.setVar("conditionUuid", uuid());
  bru.setVar("insurerOrgUuid", uuid());
  bru.setVar("practitionerRoleUuid", uuid());
  bru.setVar("practitionerUuid", uuid());
  bru.setVar("managingOrgUuid", uuid());

  const now = new Date();
  bru.setVar("isoTimestamp", now.toISOString());
  bru.setVar("inquiryDate", now.toISOString().split("T")[0]);

  const existingTxnId = bru.getVar("submitterTxnIdValue");
  if (!existingTxnId || existingTxnId === "auto") {
    const counter = String(Date.now()).slice(-6);
    bru.setVar("submitterTxnIdValue", "INQ-" + now.getFullYear() + "-" + counter);
  }

  const encStart = bru.getVar("encounterStartDateTime");
  if (!encStart) {
    bru.setVar("encounterStartDateTime", now.toISOString().replace(/\.\d+Z$/, "Z"));
  }

  const discovered = bru.getVar("payerFhirBaseUrl");
  const manual = bru.getEnvVar("baseUrl");
  if (discovered) {
    console.log("🔗 Using discovered PAS endpoint: " + discovered);
  } else if (manual) {
    bru.setVar("payerFhirBaseUrl", manual);
    console.log("ℹ️  Using manual baseUrl: " + manual);
  } else {
    console.error("❌ No PAS endpoint URL available.");
    console.error("   Set baseUrl in environment OR run Plan Net Step 1 → 2.");
  }

  const token = bru.getVar("accessToken");
  if (!token || token === "YOUR_OAUTH2_BEARER_TOKEN") {
    console.warn("⚠️  No access token set. Run OAuth request first.");
  } else {
    const expiresAt = bru.getVar("tokenExpiresAt");
    if (expiresAt && new Date(expiresAt) < new Date()) {
      console.warn("⚠️  Token may have expired (" + expiresAt + "). Re-run OAuth.");
    }
  }

  console.log("📋 Specific PA Lookup:");
  console.log("   PA Ref #:    " + (bru.getVar("priorAuthRefNumber") || "(not set)"));
  console.log("   Payer:       " + (bru.getVar("payerOrgName") || "(not set)"));
  console.log("   Provider:    " + (bru.getVar("providerOrgName") || "(not set)") + " (NPI: " + (bru.getVar("providerNpi") || "?") + ")");
  console.log("   Practitioner:" + (bru.getVar("practitionerLastName") || "(not set)") + ", " + (bru.getVar("practitionerFirstName") || ""));
  console.log("   Patient:     " + (bru.getVar("patientLastName") || "(not set)") + ", " + (bru.getVar("patientFirstName") || ""));
  console.log("   Member ID:   " + (bru.getVar("memberIdValue") || "(not set)"));
  console.log("   Dx:          " + (bru.getVar("diagnosisCode") || "(not set)") + " - " + (bru.getVar("diagnosisDisplay") || ""));
  console.log("   CPT:         " + (bru.getVar("productOrServiceCode") || "(not set)"));
  console.log("   Inquiry Date:" + bru.getVar("inquiryDate"));
  console.log("   Txn ID:      " + bru.getVar("submitterTxnIdValue"));
}

