                  "code": "pay",
                  "display": "Payer",
                  "system": "http://terminology.hl7.org/CodeSystem/organization-type"
                }
              ],
              "text": "Payer"
            }
          ],
          "resourceType": "Organization"
        }
      },
      {
        "fullUrl": "urn:uuid:{{practitionerRoleUuid}}",
        "resource": {
          "id": "{{practitionerRoleUuid}}",
          "meta": {
            "profile": [
              "http://hl7.org/fhir/us/core/StructureDefinition/us-core-practitionerrole"
            ]
          },
          "active": true,
          "organization": {
            "reference": "Organization/{{requestorOrgUuid}}"
          },
          "practitioner": {
            "reference": "Practitioner/{{practitionerUuid}}"
          },
          "telecom": [
            {
              "system": "phone",
              "value": "{{practitionerPhone}}"
            }
          ],
          "resourceType": "PractitionerRole"
        }
      },
      {
        "fullUrl": "urn:uuid:{{practitionerUuid}}",
        "resource": {
          "id": "{{practitionerUuid}}",
          "meta": {
            "profile": [
              "http://hl7.org/fhir/us/davinci-pas/StructureDefinition/profile-practitioner"
            ]
          },
          "active": true,
          "address": [
            {
              "country": "US"
            }
          ],
          "gender": "male",
          "identifier": [
            {
              "system": "http://hl7.org/fhir/sid/us-npi",
              "value": "{{practitionerNpi}}"
            }
          ],
          "name": [
            {
              "family": "{{practitionerLastName}}",
              "given": [
                "{{practitionerFirstName}}"
              ]
            }
          ],
          "telecom": [
            {
              "system": "email",
              "value": "{{practitionerEmail}}"
            }
          ],
          "resourceType": "Practitioner"
        }
      },
      {
        "fullUrl": "urn:uuid:{{managingOrgUuid}}",
        "resource": {
          "id": "{{managingOrgUuid}}",
          "meta": {
            "profile": [
              "http://hl7.org/fhir/us/davinci-pas/StructureDefinition/profile-organization"
            ]
          },
          "active": true,
          "address": [
            {
              "city": "{{managingOrgCity}}",
              "country": "US",
              "line": [
                "{{managingOrgAddressLine}}"
              ],
              "postalCode": "{{managingOrgPostalCode}}",
              "state": "{{managingOrgState}}"
            }
          ],
          "identifier": [
            {
              "system": "http://hl7.org/fhir/sid/us-npi",
              "use": "official",
              "value": "{{managingOrgNpi}}"
            }
          ],
          "name": "{{managingOrgName}}",
          "telecom": [
            {
              "system": "phone",
              "value": "{{managingOrgPhone}}"
            }
          ],
          "type": [
            {
              "coding": [
                {
                  "code": "prov",
                  "display": "Healthcare Provider",
                  "system": "http://terminology.hl7.org/CodeSystem/organization-type"
                }
              ],
              "text": "Healthcare Provider"
            }
          ],
          "resourceType": "Organization"
        }
      }
    ],
    "link": [
      {
        "relation": "self",
        "url": "{{payerFhirBaseUrl}}/Claim?_id={{claimUuid}}&_include=*"
      }
    ],
    "total": 1,
    "type": "searchset",
    "resourceType": "Bundle"
  }
}

script:post-response {
  const status = res.getStatus();
  const body = res.getBody();

  if (status === 200 && body && body.resourceType === "Bundle") {
    const claimResponses = (body.entry || [])
      .filter(e => e.resource && e.resource.resourceType === "ClaimResponse")
      .map(e => e.resource);

    if (claimResponses.length === 0) {
      console.log("ℹ️  No matching authorizations found.");
      return;
    }

    console.log("✅ Found " + claimResponses.length + " authorization(s):");

    claimResponses.forEach((cr, idx) => {
      console.log("\n  ─── Authorization " + (idx + 1) + " ───");
      console.log("  ClaimResponse ID: " + (cr.id || "(none)"));
      console.log("  Outcome:          " + (cr.outcome || "(unknown)"));
      console.log("  Disposition:      " + (cr.disposition || "(none)"));

      // Extract identifiers (Service Request ID, Case Number, Claim Identifier)
      (cr.identifier || []).forEach(ident => {
        const label = (ident.type && ident.type.text) || ident.system || "";
        console.log("  Identifier:       " + label + " = " + (ident.value || ""));
      });

      // Store first response for downstream
      if (idx === 0 && cr.id) {
        bru.setVar("lastClaimResponseId", cr.id);
        bru.setVar("lastClaimResponseOutcome", cr.outcome || "");
      }

      // Parse request reference (points back to original Claim)
      if (cr.request && cr.request.reference) {
        console.log("  Request ref:      " + cr.request.reference);
      }

      // Parse top-level adjudication (overall review action)
      (cr.adjudication || []).forEach(adj => {
        // Handle nested reviewAction complex extension
        const reviewActionExt = (adj.extension || []).find(ext =>
          ext.url && ext.url.includes("extension-reviewAction") &&
          !ext.url.includes("reviewActionCode")
        );
        if (reviewActionExt && reviewActionExt.extension) {
          const codeExt = (reviewActionExt.extension || []).find(e =>
            e.url && e.url.includes("reviewActionCode")
          );
          if (codeExt && codeExt.valueCodeableConcept) {
            const coding = (codeExt.valueCodeableConcept.coding || [])[0] || {};
            const code = coding.code || "";
            const codeMap = {
              "A1": "✅ Certified",
              "A2": "⚠️  Modified",
              "A3": "❌ Denied",
              "A4": "⏳ Pended",
              "A6": "🚫 Cancelled",
              "CT": "📞 Contact Payer"
            };
            console.log("  Overall Action:   " + (codeMap[code] || code) + " (" + (coding.display || "") + ")");
            if (idx === 0) bru.setVar("lastReviewActionCode", code);
          }
        }
      });

      // Parse item-level adjudication
      (cr.item || []).forEach((item) => {
        console.log("  Item " + item.itemSequence + ":");

        // Item-level extensions
        (item.extension || []).forEach(ext => {
          if (ext.url && ext.url.includes("administrationReferenceNumber")) {
            console.log("    Admin Ref #:  " + ext.valueString);
            if (idx === 0) bru.setVar("lastReviewNumber", ext.valueString);
          }
          if (ext.url && ext.url.includes("communicatedDiagnosis") && ext.valueCodeableConcept) {
            const dx = (ext.valueCodeableConcept.coding || [])[0] || {};
            console.log("    Diagnosis:    " + (dx.code || "") + " - " + (dx.display || ""));
          }
          if (ext.url && ext.url.includes("itemAuthorizedDetail") && ext.extension) {
            const svcExt = (ext.extension || []).find(e => e.url === "productOrServiceCode");
            if (svcExt && svcExt.valueCodeableConcept) {
              const svc = (svcExt.valueCodeableConcept.coding || [])[0] || {};
              console.log("    Auth'd CPT:   " + (svc.code || "") + " - " + (svc.text || svcExt.valueCodeableConcept.text || ""));
            }
          }
        });

        // Item adjudication
        (item.adjudication || []).forEach(adj => {
          const cat = ((adj.category || {}).coding || [])[0] || {};
          console.log("    Adjudication:  " + (cat.code || "(unknown)"));
        });
      });
    });

    // Check for CommunicationRequests (payer needs more info)
    const commReqs = (body.entry || [])
      .filter(e => e.resource && e.resource.resourceType === "CommunicationRequest");
    if (commReqs.length > 0) {
      console.log("\n  📨 " + commReqs.length + " CommunicationRequest(s) — payer needs additional info");
    }

    console.log("\n  ── Stored for downstream ──");
    console.log("  lastClaimResponseId:      " + (bru.getVar("lastClaimResponseId") || "(none)"));
    console.log("  lastClaimResponseOutcome:  " + (bru.getVar("lastClaimResponseOutcome") || "(none)"));
    console.log("  lastReviewActionCode:      " + (bru.getVar("lastReviewActionCode") || "(none)"));
    console.log("  lastReviewNumber:          " + (bru.getVar("lastReviewNumber") || "(none)"));

  } else if (status !== 200) {
    console.error("❌ $inquire failed (HTTP " + status + ")");
    if (body && body.resourceType === "OperationOutcome") {
      (body.issue || []).forEach(issue => {
        console.error("   [" + issue.severity + "] " + (issue.diagnostics || issue.code));
      });
    }
  }
}

settings {
  encodeUrl: false
  timeout: 0
}

docs {
  # Inquire - Specific PA Lookup
  
  Queries a specific prior authorization by its payer-assigned reference number
  (`administrationReferenceNumber` on item extension). Uses the full resource
  graph required by eviCore's UAT environment.
  
  ## What makes this "specific"
  The `priorAuthRefNumber` local variable populates the
  `extension-administrationReferenceNumber` on the Claim item, which is how
  eviCore matches to a single authorization. Change this value to look up
  a different PA.
  
  ## Key variables to set
  - `priorAuthRefNumber` — the payer-assigned PA number (e.g. A251852874)
  - `memberIdValue` — patient's member ID
  - `providerNpi` / `providerOrgName` — requesting facility
  - `practitionerNpi` / `practitionerLastName` — attending physician
  - `diagnosisCode` / `productOrServiceCode` — clinical details
  
  ## eviCore requirements (lessons learned)
  - Bundle must be `searchset` type with `profile-pas-request-bundle`
  - Header must be `content-type: application/json` (not `application/fhir+json`)
  - Insurer identified by NIIP code, not NPI
  - Requestor needs both NPI and TIN identifiers
  - PA ref goes on `item.extension[administrationReferenceNumber]`, NOT `Claim.identifier`
  - Full resource graph required: Encounter, Condition, ServiceRequest, 
    PractitionerRole, Practitioner, Managing Org, CareTeam (FA + 71)
  
  ## IG Reference
  Da Vinci PAS v2.0.1 (STU 2) — http://hl7.org/fhir/us/davinci-pas/STU2/
}
